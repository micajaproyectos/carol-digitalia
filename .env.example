# ----------------------------------------------------------------------------
# Google Sheets — captura de leads (service account)
# ----------------------------------------------------------------------------
# 1. Crea un proyecto en Google Cloud y habilita la API de Google Sheets.
# 2. Crea una Service Account y genera una clave JSON.
# 3. Comparte la planilla de destino con el email de la service account (Editor).
# 4. La planilla debe tener una hoja con estas columnas, en este orden:
#       timestamp | nombre | correo | teléfono | día disponible
#
# Si estas variables faltan o Sheets falla, el lead NO se pierde: la API
# responde ok igual y el front siempre redirige a WhatsApp.

# ID del documento (parte de la URL: /spreadsheets/d/<ESTE_ID>/edit)
GOOGLE_SHEETS_ID=

# Email de la service account (xxxx@xxxx.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Clave privada de la service account. Mantén las comillas y los \n escapados.
# Ej: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=""

# (Opcional) Rango/hoja destino. Por defecto usa la primera hoja: "A:E"
# Ej: "Leads!A:E"
GOOGLE_SHEETS_RANGE=
